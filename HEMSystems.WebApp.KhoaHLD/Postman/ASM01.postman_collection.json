                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const token = pm.response.text().replace(/^\"|\"$/g, '');",
                  "  pm.collectionVariables.set('token', token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"admin@hem.com\",\n  \"password\": \"123456\"\n}"
            },
